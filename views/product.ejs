<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= product.nama %> | RajaTopUp</title>

<link rel="stylesheet" href="/css/style.css">

<style>

body{
    margin:0;
    background:#111;
    color:#fff;
    font-family:Arial,Helvetica,sans-serif;
}

.container{
    max-width:500px;
    margin:20px auto;
    padding:15px;
}

.card{
    background:#1b1b1b;
    border-radius:18px;
    box-shadow:0 8px 25px rgba(0,0,0,.08);
    overflow:hidden;
}

.banner{
    background:linear-gradient(135deg,#111,#2b2b2b);
    color:#fff;
    text-align:center;
    padding:25px;
}

.banner img{
    width:70px;
    height:70px;
    border-radius:16px;
    background:#fff;
    padding:6px;
    margin-bottom:10px;
}

.banner h2{
    margin:8px 0;
}

.price{
    font-size:28px;
    font-weight:bold;
    color:#f7c948;
}

.content{
    padding:20px;
}

.section-title{
    font-size:17px;
    font-weight:bold;
    margin:18px 0 10px;
}

label{
    display:block;
    margin-bottom:6px;
    font-weight:bold;
}

input{
    width:100%;
    box-sizing:border-box;
    padding:14px;
    background:#111;
    color:#fff;
    border:1px solid #444;
    border-radius:12px;
    margin-bottom:15px;
    font-size:15px;
}

.summary{
    background:#222;
    color:#fff;    
    border-radius:12px;
    padding:15px;
    margin-top:15px;
}

.summary div{
    display:flex;
    justify-content:space-between;
    margin:8px 0;
}

.btn{
    width:100%;
    border:none;
    padding:16px;
    border-radius:12px;
    margin-top:20px;
    font-size:17px;
    font-weight:bold;
    color:#111;
    cursor:pointer;
    background:#f7c948;
}

.btn:hover{
    opacity:.9;
}

.note{
    margin-top:15px;
    color:#bbb;
    font-size:13px;
    text-align:center;
}

/* ===========================
   PAYMENT PREMIUM
=========================== */

.payment-title{
    font-size:22px;
    font-weight:700;
    margin:25px 0 15px;
    color:#222;
}

.payment-list{
    display:flex;
    flex-direction:column;
    gap:12px;
}

.payment-item{
    display:flex;
    align-items:center;
    gap:15px;
    background:#fff;
    border:2px solid #e5e7eb;
    border-radius:16px;
    padding:16px 18px;
    cursor:pointer;
    transition:.25s;
}

.payment-item:hover{
    border-color:#f7c948;
    box-shadow:0 6px 18px rgba(0,0,0,.08);
}

.payment-item input{
    accent-color:#f7c948;
    width:18px;
    height:18px;
}

.payment-item img{
    width:56px;
    height:56px;
    object-fit:contain;
    flex-shrink:0;
}

.payment-item span{
    flex:1;
    font-size:17px;
    font-weight:700;
}

.payment-item:has(input:checked){
    border-color:#f7c948;
    background:#fffdf4;
    box-shadow:0 0 12px rgba(247,201,72,.35);
}

.payment-item::after{
    content:"✔";
    color:#f7c948;
    font-weight:bold;
    opacity:0;
    transition:.25s;
}

.payment-item:has(input:checked)::after{
    opacity:1;
}

</style>

</head>

<body>

<div class="container">

<div class="card">

<div class="banner">

<img src="/images/freefire.png">

<h2><%= product.nama %></h2>

<div class="price">

Rp <%= Number(product.harga_jual).toLocaleString("id-ID") %>

</div>

</div>

<div class="content">

<form action="/checkout" method="POST">

<input
type="hidden"
name="kode"
value="<%= product.kode %>">

<div class="section-title">

🆔 Data Akun

</div>

<label>User ID Free Fire</label>

<input
type="text"
name="tujuan"
placeholder="Masukkan User ID"
required>

<input
type="hidden"
name="server_id"
value="">

<div class="section-title">

📞 Kontak

</div>

<label>Email</label>

<input
type="email"
name="email"
placeholder="contoh@gmail.com">

<label>WhatsApp</label>

<input
type="text"
name="whatsapp"
placeholder="08xxxxxxxxxx"
required>

<div class="summary">

<div>

<span>Produk</span>

<strong><%= product.nama %></strong>

</div>

<div>
    <span>Harga</span>
    <strong>
        Rp <%= Number(product.harga_jual).toLocaleString("id-ID") %>
    </strong>
</div>

<h3 class="payment-title">💳 Metode Pembayaran</h3>

<div class="payment-list">

    <label class="payment-item">
        <input type="radio" name="payment" value="qris" checked>
        <img src="/images/payment/qris.png" alt="QRIS">
        <span>QRIS</span>
    </label>

    <label class="payment-item">
        <input type="radio" name="payment" value="gopay">
        <img src="/images/payment/gopay.png" alt="GoPay">
        <span>GoPay</span>
    </label>

    <label class="payment-item">
        <input type="radio" name="payment" value="dana">
        <img src="/images/payment/dana.png" alt="DANA">
        <span>DANA</span>
    </label>

    <label class="payment-item">
        <input type="radio" name="payment" value="mandiri">
        <img src="/images/payment/mandiri.png" alt="Mandiri">
        <span>Mandiri Virtual Account</span>
    </label>

    <label class="payment-item">
        <input type="radio" name="payment" value="bni">
        <img src="/images/payment/bni.png" alt="BNI">
        <span>BNI Virtual Account</span>
    </label>

    <label class="payment-item">
        <input type="radio" name="payment" value="bsi">
        <img src="/images/payment/bsi.png" alt="BSI">
        <span>Bank Syariah Indonesia</span>
    </label>

    <label class="payment-item">
        <input type="radio" name="payment" value="seabank">
        <img src="/images/payment/seabank.png" alt="SeaBank">
        <span>SeaBank</span>
    </label>

    <label class="payment-item">
        <input type="radio" name="payment" value="alfamart">
        <img src="/images/payment/alfamart.png" alt="Alfamart">
        <span>Alfamart</span>
    </label>

</div>

</div>

<button class="btn" type="submit">

⚡ Bayar Sekarang

</button>

<div class="note">

🔒 Transaksi aman & diproses otomatis 24 jam

</div>

</form>

</div>

</div>

</div>

</body>

</html>
