<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0">

<title>

Login Admin

</title>

<link
rel="stylesheet"
href="/css/style.css">

</head>

<body class="login-page">

<div class="login-box">

<h1>

👑 RajaTopUp

</h1>

<p>

Panel Administrator

</p>

<form id="loginForm">

<input
type="text"
id="username"
placeholder="Username"
required>

<input
type="password"
id="password"
placeholder="Password"
required>

<button
type="submit">

MASUK

</button>

</form>

<p
id="msg"
class="msg">

</p>

<a
href="/">

← Kembali ke Home

</a>

</div>

<script>

document
.getElementById("loginForm")
.addEventListener(
"submit",
async(e)=>{

e.preventDefault();

const username=
document.getElementById("username").value;

const password=
document.getElementById("password").value;

const req=
await fetch(
"/admin/login",
{

method:"POST",

credentials:"include",

headers:{

"Content-Type":
"application/json"

},

body:JSON.stringify({

username,

password

})

}

);

const res=
await req.json();

if(res.success){

location.href=
"/admin/dashboard";

}else{

document
.getElementById("msg")
.innerHTML=
res.message;

}

});

</script>

</body>

</html>
