<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0">

<title>

Tambah Produk

</title>

<link
rel="stylesheet"
href="/css/style.css">

</head>

<body>

<div class="admin-layout">

<aside class="sidebar">

<h2>

👑 RajaTopUp

</h2>

<a href="/admin/dashboard">

🏠 Dashboard

</a>

<a href="/admin/products">

📦 Produk

</a>

<a href="/admin/product/add">

➕ Tambah Produk

</a>

<a href="/">

🌐 Website

</a>

</aside>

<main class="content">

<h1>

Tambah Produk

</h1>

<form
class="form"

action="/admin/product/add"

method="POST">

<label>

Nama Game

</label>

<input

type="text"

name="game"

placeholder="Contoh: Free Fire"

required>

<label>

Nama Produk

</label>

<input

type="text"

name="nama"

placeholder="Contoh: 5 Diamond"

required>

<label>

Kode Produk APIGames

</label>

<input

type="text"

name="kode"

placeholder="Contoh: FF5"

required>

<label>

Harga Modal

</label>

<input

type="number"

name="harga_modal"

placeholder="900"

required>

<label>

Harga Jual

</label>

<input

type="number"

name="harga_jual"

placeholder="1500"

required>

<label>

Status

</label>

<select name="status">

<option value="true">

Aktif

</option>

<option value="false">

Nonaktif

</option>

</select>

<div class="button-group">

<button
type="submit">

💾 Simpan Produk

</button>

<a
class="btn"

href="/admin/products">

← Kembali

</a>

</div>

</form>

</main>

</div>

</body>

</html>
