<script>

}

const slides=document.querySelectorAll(".slide");

const dots=document.querySelectorAll(".dot");

let current=0;

setInterval(()=>{

slides[current].classList.remove("active");

dots[current].classList.remove("active");

current++;

if(current>=slides.length){

current=0;

}

slides[current].classList.add("active");

dots[current].classList.add("active");

},4000);

</script>

<script>
const menuBtn = document.getElementById("menuBtn");
const closeBtn = document.getElementById("closeBtn");
const sidebar = document.getElementById("sidebarMenu");
const overlay = document.getElementById("menuOverlay");

menuBtn.addEventListener("click", () => {
    sidebar.classList.add("active");
    overlay.classList.add("active");
});

closeBtn.addEventListener("click", () => {
    sidebar.classList.remove("active");
    overlay.classList.remove("active");
});

overlay.addEventListener("click", () => {
    sidebar.classList.remove("active");
    overlay.classList.remove("active");
});
</script>

<script>

if(!localStorage.getItem("rt_splash")){

const splash=document.getElementById("splashScreen");
const title=document.getElementById("splashTitle");
const percent=document.getElementById("loadingPercent");
const fill=document.getElementById("loadingFill");

const text="RajaTopUp";

let delay=0;

for(let i=0;i<text.length;i++){

setTimeout(()=>{

const span=document.createElement("span");

span.innerHTML=text[i];

span.style.animation="flyLetter .45s forwards";

span.style.margin="0 1px";

title.appendChild(span);

},delay);

delay+=120;

}

let p=0;

const loading=setInterval(()=>{

p++;

percent.innerHTML=p+"%";

fill.style.width=p+"%";

if(p>=100){

clearInterval(loading);

setTimeout(showWelcome,500);

}

},30);

function showWelcome(){

splash.classList.add("hideSplash");

const overlay=document.getElementById("welcomeOverlay");

const box=document.getElementById("welcomeText");

overlay.style.display="flex";

const msg=[
"Selamat Datang di",
"👑 RajaTopUp",
"Selamat Berbelanja"
];

let line=0;

function nextLine(){

if(line>=msg.length){

setTimeout(()=>{

overlay.style.transition=".6s";

overlay.style.opacity="0";

setTimeout(()=>{

overlay.remove();

localStorage.setItem("rt_splash","done");

},600);

},4000);

return;

}

const div=document.createElement("div");

box.appendChild(div);

let i=0;

const huruf=setInterval(()=>{

if(i>=msg[line].length){

clearInterval(huruf);

line++;

setTimeout(nextLine,300);

return;

}

const span=document.createElement("span");

span.innerHTML=msg[line][i]==" " ? "&nbsp;" : msg[line][i];

span.style.animation="flyLetter .35s forwards";

div.appendChild(span);

i++;

},45);

}

nextLine();

}

}else{

document.getElementById("splashScreen").remove();

document.getElementById("welcomeOverlay").remove();

}

</script>

<script>
const banners = [
    "/images/freefire1.png",
    "/images/freefire2.png",
    "/images/freefire3.png",
    "/images/freefire4.png"
];

let index = 0;

setInterval(() => {
    index = (index + 1) % banners.length;
    document.getElementById("bannerImage").src = banners[index];
}, 5000);
</script>

</body>

</html>
