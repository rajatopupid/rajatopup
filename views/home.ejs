    🔒 Kebijakan Privasi
</a>

<a href="/terms" class="menu-btn">
    📜 Syarat & Ketentuan
</a>

<a href="/refund" class="menu-btn">
    💸 Kebijakan Refund
</a>

<a href="/disclaimer" class="menu-btn">
    ⚠️ Disclaimer
</a>

</div>

<div class="menu-overlay" id="menuOverlay"></div>

<section class="banner-slider">
    <img id="bannerImage" src="/images/freefire1.png" alt="Banner">
</section>

</section>

<section
class="product-grid"

id="productGrid">

<% products.forEach(p=>{ %>

<a href="/product/<%= p.kode %>" class="game-card">

