<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>
<%= settings.website || "RajaTopUp" %>
</title>

<link rel="stylesheet"
href="/css/style.css">

</head>

<body>

<header class="topbar">

    <div class="logo-area">

        <div class="logo-icon">
            👑
        </div>

        <div>

            <h2><%= settings.website || "RajaTopUp" %></h2>

            <small>Top Up Game Otomatis</small>

        </div>

    </div>

    <div class="top-icons">

        <button class="icon-btn">
            🔔
        </button>

        <button class="icon-btn">
            ☰
        </button>

    </div>

</header>


<section class="hero">

    <div class="hero-slider">

        <div class="slide active">

            <div class="slide-content">

                <span class="badge">
                    PROMO
                </span>

                <h1>

                    Top Up Game
                    Murah &
                    Instan

                </h1>

                <p>

                    Diamond masuk otomatis
                    dalam hitungan detik.

                </p>

                <a href="#productGrid" class="hero-btn">

                    Top Up Sekarang

                </a>

            </div>

        </div>

        <div class="slide">

            <div class="slide-content">

                <span class="badge">
                    EVENT
                </span>

                <h1>

                    Cashback
                    Hingga 10%

                </h1>

                <p>

                    Berlaku untuk semua
                    metode pembayaran.

                </p>

            </div>

        </div>

        <div class="slide">

            <div class="slide-content">

                <span class="badge">
                    TERBARU
                </span>

                <h1>

                    Pembayaran
                    Lengkap

                </h1>

                <p>

                    QRIS
                    DANA
                    GoPay
                    VA

                </p>

            </div>

        </div>

    </div>

</section>

<section class="category-scroll">

<button class="category-item active">

🔥 Semua

</button>

<button class="category-item">

🎮 Populer

</button>

<button class="category-item">

💎 Diamond

</button>

<button class="category-item">

🎫 Voucher

</button>

<button class="category-item">

⭐ Baru

</button>

</section>

<section class="section-title">

<h2>

🎮 Semua Game

</h2>

<p>

Pilih game favoritmu

</p>

</section>

<section
class="product-grid"

id="productGrid">

<% products.forEach(p=>{ %>

<a href="/product/<%= p.kode %>" class="game-card">

<div class="game-image">

<img
src="/images/<%= (p.game || 'default').toLowerCase().replace(/\s+/g,'') %>.png"
onerror="this.src='/images/default.png'">

<span class="badge-popular">

🔥 Populer

</span>

</div>

<div class="game-info">

<h3>

<%= p.nama %>

</h3>

<p>

<%= p.game %>

</p>

<div class="price">

Mulai

<strong>

Rp <%= Number(p.harga_jual || 0).toLocaleString("id-ID") %>

</strong>

</div>

<button class="buy-btn">

Top Up →

</button>

</div>

</a>

<% }) %>

</section>

<footer>

<h3>👑 RajaTopUp</h3>

<p>

Top Up Game Otomatis 24 Jam

</p>

<br>

<p>

© 2026 RajaTopUp

</p>

</footer>

<script>

function filterProduct(){

let keyword=document
.getElementById("search")
.value
.toLowerCase();

let cards=
document.querySelectorAll(".card");

cards.forEach(card=>{

let text=
card.innerText
.toLowerCase();

card.style.display=
text.includes(keyword)
?"block":"none";

});

}

</script>

</body>

</html>
