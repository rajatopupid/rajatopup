<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>
<%= settings.website || "RajaTopUp" %>
</title>

<link rel="stylesheet"
href="/css/style.css">

</head>

<body>

<header class="topbar">

<div class="logo">

👑 RajaTopUp

</div>

<div class="menu-right">

<button>

🔔

</button>

<button>

☰

</button>

</div>

</header>

<section class="ff-banner">
    <img src="/images/freefire.png" alt="Free Fire">
    <div class="ff-text">
        <span>🔥 Free Fire</span>
        <h2>Top Up Diamond Free Fire</h2>
        <p>Proses Otomatis • 24 Jam • Harga Termurah</p>
    </div>
</section>

</section>

<section
class="product-grid"

id="productGrid">

<% products.forEach(p=>{ %>

<a href="/product/<%= p.kode %>" class="game-card">

<div class="game-image">

<img
src="/images/<%= (p.game || 'default').toLowerCase().replace(/\s+/g,'') %>.png"
onerror="this.src='/images/default.png'">

<span class="badge-popular">

🔥 Populer

</span>

</div>

<div class="game-info">

<h3>

<%= p.nama %>

</h3>

<p>

<%= p.game %>

</p>

<div class="price">

Mulai

<strong>

Rp <%= Number(p.harga_jual || 0).toLocaleString("id-ID") %>

</strong>

</div>

<button class="buy-btn">

Top Up →

</button>

</div>

</a>

<% }) %>

</section>

<footer>

<h3>👑 RajaTopUp</h3>

<p>

Top Up Game Otomatis 24 Jam

</p>

<br>

<p>

© 2026 RajaTopUp

</p>

</footer>

<script>

}

const slides=document.querySelectorAll(".slide");

const dots=document.querySelectorAll(".dot");

let current=0;

setInterval(()=>{

slides[current].classList.remove("active");

dots[current].classList.remove("active");

current++;

if(current>=slides.length){

current=0;

}

slides[current].classList.add("active");

dots[current].classList.add("active");

},4000);

</script>

</body>

</html>
