<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>
<%= settings.website || "RajaTopUp" %>
</title>

<link rel="stylesheet"
href="/css/style.css">

</head>

<body>

<header class="topbar">

<div class="logo">

👑 RajaTopUp

</div>

<div class="menu-right">

<button>

🔔

</button>

<button>

☰

</button>

</div>

</header>

<div class="slide active">

<span class="hero-badge">🔥 FREE FIRE</span>

<h1>Top Up Diamond Free Fire</h1>

<p>Murah • Cepat • Otomatis 24 Jam</p>

<a href="#productGrid" class="hero-btn">
Top Up Sekarang →
</a>

</div>

<div class="slide">

<span class="hero-badge">🎁 PROMO</span>

<h1>Diamond Harga Terbaik</h1>

<p>Member Mingguan • Member Bulanan • Diamond</p>

<a href="#productGrid">
Lihat Produk →
</a>

</div>

<div class="slide">

<span class="hero-badge">💳 PEMBAYARAN</span>

<h1>QRIS • DANA • GoPay</h1>

<p>Pembayaran otomatis 24 jam</p>

<a href="#">
Lihat Metode →
</a>

</div>

<div class="slider-dot">

<span class="dot active"></span>

<span class="dot"></span>

<span class="dot"></span>

</div>

</div>

</section>

<section
class="product-grid"

id="productGrid">

<% products.forEach(p=>{ %>

<a href="/product/<%= p.kode %>" class="game-card">

<div class="game-image">

<img
src="/images/<%= (p.game || 'default').toLowerCase().replace(/\s+/g,'') %>.png"
onerror="this.src='/images/default.png'">

<span class="badge-popular">

🔥 Populer

</span>

</div>

<div class="game-info">

<h3>

<%= p.nama %>

</h3>

<p>

<%= p.game %>

</p>

<div class="price">

Mulai

<strong>

Rp <%= Number(p.harga_jual || 0).toLocaleString("id-ID") %>

</strong>

</div>

<button class="buy-btn">

Top Up →

</button>

</div>

</a>

<% }) %>

</section>

<footer>

<h3>👑 RajaTopUp</h3>

<p>

Top Up Game Otomatis 24 Jam

</p>

<br>

<p>

© 2026 RajaTopUp

</p>

</footer>

<script>

}

const slides=document.querySelectorAll(".slide");

const dots=document.querySelectorAll(".dot");

let current=0;

setInterval(()=>{

slides[current].classList.remove("active");

dots[current].classList.remove("active");

current++;

if(current>=slides.length){

current=0;

}

slides[current].classList.add("active");

dots[current].classList.add("active");

},4000);

</script>

</body>

</html>
