<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>
<%= settings.website || "RajaTopUp" %>
</title>

<link rel="stylesheet"
href="/css/style.css">

</head>

<body>

<header class="topbar">

<div class="logo">

👑 RajaTopUp

</div>

<div class="menu-right">

<button>

🔔

</button>

<button>

☰

</button>

</div>

</header>

<section class="hero">

<div class="hero-overlay">

<div class="hero-left">

<span class="hero-badge">

🔥 PROMO HARI INI

</span>

<h1>

Top Up Game
Murah, Cepat &
Aman 24 Jam

</h1>

<p>

Proses instan • Harga terbaik • Support 24 Jam

</p>

<a href="#productGrid" class="hero-btn">

Top Up Sekarang →

</a>

</div>

<div class="hero-right">

<img src="/images/hero.png"
onerror="this.style.display='none'">

</div>

</div>

</section>

<section class="category-scroll">

<div class="chip active">

🔥 Semua

</div>

<div class="chip">

🎮 Populer

</div>

<div class="chip">

💎 Free Fire

</div>

<div class="chip">

⚔ Mobile Legends

</div>

<div class="chip">

🎯 PUBG

</div>

<div class="chip">

⭐ Valorant

</div>

</section>

<section
class="product-grid"

id="productGrid">

<% products.forEach(p=>{ %>

<a href="/product/<%= p.kode %>" class="game-card">

<div class="game-image">

<img
src="/images/<%= (p.game || 'default').toLowerCase().replace(/\s+/g,'') %>.png"
onerror="this.src='/images/default.png'">

<span class="badge-popular">

🔥 Populer

</span>

</div>

<div class="game-info">

<h3>

<%= p.nama %>

</h3>

<p>

<%= p.game %>

</p>

<div class="price">

Mulai

<strong>

Rp <%= Number(p.harga_jual || 0).toLocaleString("id-ID") %>

</strong>

</div>

<button class="buy-btn">

Top Up →

</button>

</div>

</a>

<% }) %>

</section>

<footer>

<h3>👑 RajaTopUp</h3>

<p>

Top Up Game Otomatis 24 Jam

</p>

<br>

<p>

© 2026 RajaTopUp

</p>

</footer>

<script>

function filterProduct(){

let keyword=document
.getElementById("search")
.value
.toLowerCase();

let cards=
document.querySelectorAll(".card");

cards.forEach(card=>{

let text=
card.innerText
.toLowerCase();

card.style.display=
text.includes(keyword)
?"block":"none";

});

}

</script>

</body>

</html>
