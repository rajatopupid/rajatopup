<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>
<%= settings.website || "RajaTopUp" %>
</title>

<link rel="stylesheet"
href="/css/style.css">

</head>

<body>

<header class="header">

<div class="logo">

👑
<%= settings.website || "RajaTopUp" %>

</div>

<nav>

<a href="/">Home</a>

<a href="/about">Tentang</a>

<a href="/contact">Kontak</a>

<a href="/faq">FAQ</a>

<% if(admin){ %>

<a href="/admin/dashboard">
Dashboard
</a>

<% }else{ %>

<a href="/admin/login">
Admin
</a>

<% } %>

</nav>

</header>

<section class="hero">

<div class="banner">

<div>

<h1>👑 RajaTopUp</h1>

<p>Top Up Game Otomatis • Cepat • Aman 24 Jam</p>

<a class="btn" href="#productGrid">
Top Up Sekarang
</a>

</div>

</div>

</section>

<section class="search">

<input

type="text"

id="search"

placeholder="Cari game..."

onkeyup="filterProduct()"

>

</section>

<section class="category">

<h2>🔥 Game Populer</h2>

</section>


<section
class="product-grid"

id="productGrid">

<% products.forEach(p=>{ %>

<div class="card">

<div class="card-header">

<img
src="/images/<%= (p.game || 'default').toLowerCase().replace(/\s+/g,'') %>.png"
onerror="this.src='/images/default.png'">

<h3><%= p.nama %></h3>

<p><%= p.game %></p>

</div>

<div class="card-body">

<small>Mulai Dari</small>

<h2>

Rp <%= Number(p.harga_jual || 0).toLocaleString("id-ID") %>

</h2>

</div>

<div class="card-footer">

<a
class="btn"
href="/product/<%= p.kode %>">

Top Up

</a>

</div>

</div>

<% }) %>

</section>

<footer>

<h3>👑 RajaTopUp</h3>

<p>

Top Up Game Otomatis 24 Jam

</p>

<br>

<p>

© 2026 RajaTopUp

</p>

</footer>

<script>

function filterProduct(){

let keyword=document
.getElementById("search")
.value
.toLowerCase();

let cards=
document.querySelectorAll(".card");

cards.forEach(card=>{

let text=
card.innerText
.toLowerCase();

card.style.display=
text.includes(keyword)
?"block":"none";

});

}

</script>

</body>

</html>
